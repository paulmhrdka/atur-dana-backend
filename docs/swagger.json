                            "$ref": "#/definitions/atur-dana_internal_common.SwaggerErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/atur-dana_internal_common.SwaggerErrorResponse"
                        }
                    }
                }
