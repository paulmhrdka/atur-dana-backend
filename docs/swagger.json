                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/atur-dana_internal_responses.SwaggerAuthResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
