                    }
                },
                "status": {
                    "type": "string",
                    "example": "error"
                }
            }
        },
        "atur-dana_internal_requests.CreateBudgetRequest": {
            "type": "object",
            "required": [
                "amount",
                "category_id",
                "end_date",
                "start_date"
            ],
            "properties": {
                "amount": {
                    "type": "number",
                    "example": 1000000
                },
                "category_id": {
                    "type": "integer",
                    "example": 2
                },
                "end_date": {
                    "type": "string",
                    "example": "2026-03-31 23:59:59"
                },
                "start_date": {
                    "type": "string",
                    "example": "2026-03-01 00:00:00"
                }
            }
        },
        "atur-dana_internal_requests.CreateTransactionRequest": {
            "type": "object",
            "required": [
                "amount",
                "category_id",
                "date",
                "description",
                "type"
            ],
            "properties": {
                "amount": {
                    "type": "number",
                    "example": 50000
                },
                "category_id": {
                    "type": "integer",
                    "example": 1
                },
                "date": {
                    "type": "string",
                    "example": "2026-03-01 00:00:00"
                },
                "description": {
                    "type": "string",
                    "example": "Monthly salary"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "income",
                        "expense"
                    ],
                    "example": "income"
                }
            }
        },
        "atur-dana_internal_requests.LoginRequest": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "john@example.com"
                },
                "password": {
                    "type": "string",
                    "example": "secret123"
                }
            }
        },
        "atur-dana_internal_requests.RegisterRequest": {
            "type": "object",
            "required": [
                "email",
                "password",
                "username"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "example": "john@example.com"
                },
                "password": {
                    "type": "string",
                    "example": "secret123"
                },
                "username": {
                    "type": "string",
                    "example": "johndoe"
                }
            }
        },
        "atur-dana_internal_responses.AuthResponse": {
            "type": "object",
            "properties": {
                "token": {
                    "type": "string"
                },
                "user": {
                    "$ref": "#/definitions/atur-dana_internal_responses.User"
                }
            }
        },
